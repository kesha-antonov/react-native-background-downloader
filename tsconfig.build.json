{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2019", "DOM"],
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-native",
    "noEmit": false
  },
  "include": ["src/**/*.ts"]
}
